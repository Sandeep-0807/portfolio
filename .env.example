# API / MySQL configuration
# Copy this file to .env and fill in your values.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=portfolio

# API server port
API_PORT=5050

# Frontend API base URL (optional)
# Use this when running `npm run preview` or hosting the built site separately from the API.
# Example: VITE_API_BASE=http://localhost:5050
VITE_API_BASE=

# Supabase (recommended for deployed Admin edits)
# Create a Supabase project, then set these in Vercel (Project Settings → Environment Variables)
VITE_SUPABASE_URL=
# Use one of the following keys:
# - Legacy: VITE_SUPABASE_ANON_KEY
# - New Supabase UI: VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional: Supabase Storage bucket for uploads used by the Admin UI
# Create a bucket with this name and make it public (or configure policies).
VITE_SUPABASE_STORAGE_BUCKET=uploads

# Offline Admin mode (no API/DB)
# When enabled, admin/public data is stored in your browser localStorage (this device only).
# NOTE: Not secure; do not enable for public deployments.
VITE_OFFLINE_ADMIN=

# Optional password check for offline admin login.
# If set, the Admin Login password must match this value.
VITE_LOCAL_ADMIN_PASSWORD=

# Admin user seeding (used by: npm run create-admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
